{
  "name": "atlas",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "GitHub PR to project brief generator.",
  "scripts": {
    "brief": "tsx src/cli/main.ts brief",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "format": "prettier . --write --ignore-unknown",
    "format:check": "prettier . --check --ignore-unknown"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mauricio-azevedo/atlas.git"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/mauricio-azevedo/atlas/issues"
  },
  "homepage": "https://github.com/mauricio-azevedo/atlas#readme",
  "devDependencies": {
    "@types/node": "^24.0.0",
    "prettier": "^3.8.3",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0"
  }
}
